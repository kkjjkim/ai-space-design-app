# ── Supabase ─────────────────────────────────────────────
# Supabase 프로젝트 > Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci...(anon public key)"

# ── 메일 알림 (Resend) ───────────────────────────────────
# https://resend.com 에서 발급. 서버에서만 사용 (NEXT_PUBLIC 아님)
RESEND_API_KEY="re_xxxxxxxx"
# 알림 받을 운영자 이메일 (쉼표로 여러 명 가능)
LEAD_NOTIFY_TO="owner@example.com"
# 발신 주소 (Resend 에서 인증한 도메인. 미설정 시 onboarding 주소 사용)
LEAD_NOTIFY_FROM="상담신청 <onboarding@resend.dev>"

# ── 네이버 쇼핑 검색 API (arbitrage 사입가 자동수집) ──────
# https://developers.naver.com > 애플리케이션 등록 > "검색" API 추가 후 발급
NAVER_CLIENT_ID="xxxxxxxxxxxx"
NAVER_CLIENT_SECRET="xxxxxxxx"
